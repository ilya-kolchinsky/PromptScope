# LLM Configuration
# Providers: "mock", "anthropic", "openai", "vllm", "ollama"
LLM_PROVIDER=mock

# Anthropic API Configuration (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI API Configuration (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# vLLM Configuration (if LLM_PROVIDER=vllm)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=default

# Ollama Configuration (if LLM_PROVIDER=ollama)
# NOTE: Use the /v1 endpoint (OpenAI-compatible), not /api
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3:latest

# Server Configuration
HOST=0.0.0.0
PORT=8000
